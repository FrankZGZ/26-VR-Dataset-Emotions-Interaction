      m_Calls: []
  m_text: "<b>Welcome to the VR Study!</b>\n\n<b>Overview:</b>\n\u2022 You will experience
    6 scenes.\n\u2022 After each scene, please finish a survey and two tasks.\n\n<b>Exiting
    Scenes:</b>\n\u2022 Each scene initially lasts for 60 seconds.\r\n\u2022 After
    60 seconds, an Exit Pad will appear by the starting point. \r\n\u2022 Teleport
    to the Exit Pad to end the scene, or continue exploring.\n\u2022You will come
    back to the mixed reality after each scene.\n\n<b>Controls (Left and Right Controller):</b>\n\u2022
    <b>Thumbstick:</b> Push and release to move.\n\u2022 <b>Grip Button:</b> Press
    to grab objects.\n\u2022 <b>Trigger Button:</b> Press to select buttons.\n\nWhen
    you're ready, try to grab the blue cube on you right, throw it,  and then teleport
    to the Exit Pad to finish the tasks."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
