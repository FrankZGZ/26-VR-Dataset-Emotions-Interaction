GROQ_API_KEY=
ELEVENLABS_API_KEY=

# ElevenLabs voice used for Unity avatar replies.
ELEVENLABS_ENABLED=1
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_FALLBACK_MODEL_IDS=eleven_multilingual_v2,eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=pcm_24000
ELEVENLABS_TIMEOUT_SECONDS=45
ELEVENLABS_STREAMING_ENABLED=1
ELEVENLABS_STREAM_CHUNK_BYTES=4096
ELEVENLABS_STREAM_END_SILENCE_MS=900
ELEVENLABS_TONE_PRESET=observer
# observer dom sub (the Unity client condition overrides this fallback for LLM wording)
ELEVENLABS_MANUAL_VOICE_SETTINGS=0
ELEVENLABS_STABILITY=0.32
ELEVENLABS_SIMILARITY_BOOST=0.78
ELEVENLABS_STYLE=0.55
ELEVENLABS_SPEED=1.0
ELEVENLABS_USE_SPEAKER_BOOST=1
GROQ_REPLY_MAX_TOKENS=300

# Local VibeVoice checkout. setup_vibevoice.ps1 uses this by default.
VIBEVOICE_REPO=D:\leetcode\VibeVoice
VIBEVOICE_PYTHON=D:\leetcode\VibeVoice\.venv\Scripts\python.exe
VIBEVOICE_MODEL=microsoft/VibeVoice-Realtime-0.5B
VIBEVOICE_SPEAKER=Emma
VIBEVOICE_DEVICE=cuda
VIBEVOICE_TIMEOUT_SECONDS=20
VIBEVOICE_ENABLED=0
VIBEVOICE_PRELOAD=0
VIBEVOICE_USE_WORKER=1
VIBEVOICE_PRELOAD_TIMEOUT_SECONDS=300
WINDOWS_TTS_FIRST=0
SEND_TEST_WAV_FIRST=0
WINDOWS_TTS_FALLBACK=1

TTS_PROVIDER=elevenlabs
GEMINI_TTS_ENABLED=0
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_TIMEOUT_SECONDS=45
GEMINI_TTS_DETACHED_VOICE=Schedar
GEMINI_TTS_SUPPORTIVE_VOICE=Sulafat
GEMINI_TTS_GUIDE_VOICE=Iapetus

# Keep downloaded VibeVoice/HuggingFace/PyTorch model files off C:.
HF_HOME=D:\leetcode\model-cache\huggingface
TRANSFORMERS_CACHE=D:\leetcode\model-cache\huggingface\transformers
TORCH_HOME=D:\leetcode\model-cache\torch

# Unity websocket server.
HOST=0.0.0.0
PORT=8080

# Optional: context file used by AI mode.
ANALYSIS_TXT_PATH=D:\leetcode\avartar-server\data\12.19\ISMAR_FullPaper_Context.txt
CONVERSATION_LOG_PATH=D:\leetcode\avartar-server\conversation_history.txt
VOICE_RECORDINGS_DIR=D:\leetcode\26-VR-Dataset-Emotions-Interaction\voice_recordings
TRANSCRIPTION_LOG_PATH=D:\leetcode\26-VR-Dataset-Emotions-Interaction\voice_transcripts.txt
